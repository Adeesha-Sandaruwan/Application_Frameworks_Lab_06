<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Social Media Feed</title>
</head>
<body>
    <h1>My Social Media Feed</h1>
    
    {{#each posts}}
        <div style="border: 1px solid #ccc; padding: 15px; margin-bottom: 20px;">
            <h2>{{this.title}}</h2>
            <p>{{this.content}}</p>
            <p><small>Author: {{this.author}}</small></p>
            
            {{#if this.imageUrl}}
                <img src="/{{this.imageUrl}}" alt="Post Image" style="max-width: 300px; display: block;">
            {{/if}}
        </div>
    {{else}}
        <p>No posts available yet!</p>
    {{/each}}
</body>
</html>